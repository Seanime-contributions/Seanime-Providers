{
  "id": "anilist-notifications",
  "name": "AniList Notifications",
  "version": "1.0.0",
  "manifestURI": "https://raw.githubusercontent.com/Pal-droid/Seanime-Providers/refs/heads/main/src/plugins/anilist-notifications/manifest.json",
  "language": "typescript",
  "type": "plugin",
  "description": "Shows AniList notifications in a tray icon.",
  "author": "Pal",
  "icon": "https://anilist.co/img/icons/favicon-32x32.png",
  "website": "",
  "lang": "multi",
  "payloadURI": "https://raw.githubusercontent.com/Pal-droid/Seanime-Providers/refs/heads/main/src/plugins/anilist-notifications/provider.ts",
  "plugin": {
    "version": "1",
    "permissions": {
      "scopes": ["anilist-token"],
      "allow": {
        "networkAccess": {
          "allowedDomains": ["anilist.co", "graphql.anilist.co"],
          "reasoning": "Required to fetch notifications from AniList GraphQL API"
        }
      }
    }
  },
  "isDevelopment": false
}